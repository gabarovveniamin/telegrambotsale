[Unit]
Description=Telegram Discount Monitor Bot
After=network.target

[Service]
User=venag
Group=venag
WorkingDirectory=/home/venag/telegrambotsale
# Используем xvfb-run для обхода Cloudflare в режиме headed
ExecStart=/usr/bin/xvfb-run -a /home/venag/telegrambotsale/venv/bin/python main.py
Restart=always
RestartSec=5
EnvironmentFile=/home/venag/telegrambotsale/.env

[Install]
WantedBy=multi-user.target
