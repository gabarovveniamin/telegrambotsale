[Unit]
Description=Telegram Discount Monitor Bot
After=network.target
[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/telegrambotsale
ExecStart=/usr/bin/xvfb-run -a /home/ubuntu/telegrambotsale/venv/bin/python3 main.py
Restart=always
RestartSec=5
EnvironmentFile=/home/ubuntu/telegrambotsale/.env
[Install]
WantedBy=multi-user.target